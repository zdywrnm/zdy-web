---
import type { CollectionEntry } from 'astro:content';
import { ui, type Lang } from '../i18n/ui';
import { projectHref } from '../lib/projects';

export interface Props {
  project: CollectionEntry<'projects'>;
  lang?: Lang;
}

const { project, lang = 'zh' } = Astro.props;
const t = ui[lang].project;
const { title, description, tech, repo, demo, role, period, cover, nodes = [] } = project.data;
const href = projectHref(project);
const visualTitle = title.includes('PaperBanana')
  ? ['Paper', 'Banana']
  : title.split(/[\s/]+/).length > 1
    ? title.split(/[\s/]+/).slice(0, 2)
    : [title.slice(0, 4), title.slice(4, 8)].filter(Boolean);
const visualNodes = nodes.length > 0 ? nodes.slice(0, 4) : tech.slice(0, 4);
---

<article class="project-feature">
  <div class="project-content">
    <h3 class="project-title">{title}</h3>
    <p class="project-description">{description}</p>
    {(role || period) && (
      <p class="project-meta-line">
        {[role, period].filter(Boolean).join(' / ')}
      </p>
    )}
    <ul class="tech-list" aria-label={`${title} ${t.techStackSuffix}`}>
      {tech.map((item) => <li>{item}</li>)}
    </ul>
    <div class="project-actions">
      <a class="button button-primary" href={href}>{t.learnMore}</a>
      {repo && <a class="button button-secondary" href={repo} target="_blank" rel="noreferrer">{t.github}</a>}
      {demo && <a class="button button-secondary" href={demo} target="_blank" rel="noreferrer">Demo</a>}
    </div>
  </div>
  <div class="project-visual">
    {cover ? (
      <img
        class="project-cover"
        src={cover}
        alt={`${title} ${t.coverAltSuffix}`}
        width="1440"
        height="900"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="diagram-panel" aria-hidden="true">
        <span class="diagram-orbit"></span>
        <span class="diagram-orbit"></span>
        <span class="diagram-orbit"></span>
        <span class="diagram-core">
          {visualTitle.map((part) => <>{part}<br /></>)}
        </span>
        {visualNodes.map((node, index) => (
          <span class={`diagram-node node-${index + 1}`}>{node}</span>
        ))}
      </div>
    )}
  </div>
</article>
