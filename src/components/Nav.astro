---
import { SOCIAL } from '../consts';
import { ui, localizePath, toLangPath, type Lang } from '../i18n/ui';

export interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = ui[lang].nav;
const pathname = Astro.url.pathname;

const homeHref = localizePath('/', lang);
const workHref = localizePath('/projects/', lang);
const aboutHref = localizePath('/about/', lang);
const isActive = (href: string) => pathname === href || pathname.startsWith(href);

const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const altHref = toLangPath(pathname, otherLang);
const altLabel = otherLang === 'en' ? 'Switch to English' : '切换到中文';
---

<header class="site-nav">
  <div class="container nav-inner">
    <a class="brand" href={homeHref} aria-label="赵鼎熠 / yrjm">
      <span class="brand-mark">ZDY</span>
      <span>赵鼎熠 / yrjm</span>
    </a>
    <nav class="nav-links" aria-label="主导航">
      <a class:list={['nav-link', isActive(workHref) && 'is-active']} href={workHref}>{t.work}</a>
      <a class:list={['nav-link', isActive(aboutHref) && 'is-active']} href={aboutHref}>{t.about}</a>
      <a class="icon-button" href={SOCIAL.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.59 2 12.253c0 4.53 2.865 8.372 6.839 9.728.5.094.683-.222.683-.494 0-.244-.009-.891-.014-1.749-2.782.62-3.369-1.374-3.369-1.374-.455-1.185-1.11-1.5-1.11-1.5-.908-.636.069-.623.069-.623 1.004.072 1.532 1.057 1.532 1.057.892 1.567 2.34 1.114 2.91.852.091-.662.35-1.114.636-1.37-2.221-.258-4.555-1.138-4.555-5.065 0-1.119.39-2.034 1.03-2.751-.103-.26-.446-1.303.098-2.714 0 0 .84-.276 2.75 1.051A9.349 9.349 0 0 1 12 6.956a9.35 9.35 0 0 1 2.504.345c1.909-1.327 2.748-1.05 2.748-1.05.546 1.41.203 2.454.1 2.713.64.717 1.028 1.632 1.028 2.751 0 3.937-2.337 4.804-4.565 5.057.359.318.678.944.678 1.902 0 1.372-.012 2.479-.012 2.815 0 .274.18.593.688.493C19.138 20.621 22 16.782 22 12.253 22 6.59 17.523 2 12 2Z" clip-rule="evenodd" />
        </svg>
      </a>
      <a class="nav-link lang-switch" href={altHref} hreflang={otherLang} aria-label={altLabel}>{t.langSwitch}</a>
      <button class="icon-button" type="button" data-theme-toggle aria-label={t.themeToggle} aria-pressed="false">
        <svg class="theme-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M21 14.5A8.5 8.5 0 0 1 9.5 3a7 7 0 1 0 11.5 11.5Z" />
        </svg>
        <svg class="theme-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2m0 16v2M4 12H2m20 0h-2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19" />
        </svg>
      </button>
    </nav>
  </div>
</header>
