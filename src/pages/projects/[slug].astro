---
import ProjectDetail from '../../components/pages/ProjectDetail.astro';
import { getProjectsByLang, projectSlug } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await getProjectsByLang('zh');
  return projects.map((project) => ({
    params: { slug: projectSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<ProjectDetail project={project} lang="zh" />
