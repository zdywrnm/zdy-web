---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui } from '../i18n/ui';

const zh = ui.zh.notFound;
const en = ui.en.notFound;
---

<BaseLayout title={zh.title} description={ui.zh.meta.notFound.desc} lang="zh">
  <section class="page-hero">
    <div class="container">
      <h1 class="page-title">404</h1>
      <p class="page-copy">{zh.copy}</p>
      <p class="page-copy">{en.copy}</p>
      <div class="hero-actions" style="justify-content: flex-start;">
        <a class="button button-primary" href="/">{zh.backHome}</a>
        <a class="button button-secondary" href="/en/">{en.backHome}</a>
      </div>
    </div>
  </section>
</BaseLayout>
